@model IEnumerable<ContactInfo>

<h2>Contacts</h2>

<p>
    <a asp-action="AddContact">Create New</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Mobile</th>
            <th>Company</th>
            <th>Department</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FirstName @item.LastName</td>
                <td>@item.EmailId</td>
                <td>@item.MobileNo</td>
                <td>@item.CompanyName</td>
                <td>@item.DepartmentName</td>

                <td>
                    <a asp-action="EditContact" asp-route-id="@item.ContactId">Edit</a> |
                    <a asp-action="DeleteContact" asp-route-id="@item.ContactId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>